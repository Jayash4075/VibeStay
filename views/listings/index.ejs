<% layout("/layouts/boilerplate") %>

<style>
    #filters{
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        
    }
    .filter{
        text-align: center;
        margin-right: 1.6rem;
        margin-top: 1.6rem;
        opacity: 0.7;
    }
    .filter:hover{
        opacity: 1;
        cursor: pointer;
        transform: scaleX(1.04);
        transition: transform 0.2s ease;
    }
    .filter p{
        font-size: 0.9rem;
    }
    .badge{
        display: none;
    }
    .toggle-switch{
        
        border: 1px solid black;
        border-radius: 10px;
        height: 3.25rem;
        display: flex;
        align-items: center;
        padding: 0px 8px;
        

    }
    @media (max-width: 767.98px) {
     #filters {
        flex-wrap: nowrap !important;       
        overflow-x: auto !important;       
        justify-content: flex-start !important; 
        padding-bottom: 8px; 
        scrollbar-width: none;       
        -ms-overflow-style: none;  
    } 
    .filter {
        flex: 0 0 auto;                     
        margin-top: 0.8rem;                
        margin-right: 1.2rem;           
    }
    #filters::-webkit-scrollbar {
        display: none;
    }
} 
</style>

    <div id="filters" class="shadow p-3 mb-5 bg-body-tertiary rounded">
        <div class="filter">
            <div><i class="ri-fire-line"></i></div>
            <p>Trending</p>
        </div>
        <div class="filter">
            <div><i class="ri-hotel-bed-fill"></i></div>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <div></i><i class="ri-building-line"></i></div>
            <p>Iconic city</p>
        </div>
        
        <div class="filter">
            <div><i class="ri-tent-line"></i> </div>
            <p>Camping</p>
        </div>
        <div class="filter">
            <div><i class="ri-snowflake-line"></i></div>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <div><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mountain-icon lucide-mountain"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg></div>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <div><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tent-tree-icon lucide-tent-tree"><circle cx="4" cy="4" r="2"/><path d="m14 5 3-3 3 3"/><path d="m14 10 3-3 3 3"/><path d="M17 14V2"/><path d="M17 14H7l-5 8h20Z"/><path d="M8 14v8"/><path d="m9 14 5 8"/></svg></div>
            <p>Camping</p>
        </div>
        <div class="filter">
            <div><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-castle-icon lucide-castle"><path d="M10 5V3"/><path d="M14 5V3"/><path d="M15 21v-3a3 3 0 0 0-6 0v3"/><path d="M18 3v8"/><path d="M18 5H6"/><path d="M22 11H2"/><path d="M22 9v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9"/><path d="M6 3v8"/></svg></div>
            <p>Castles</p>
        </div>
        <div class="filter">
            <div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ship-icon lucide-ship"><path d="M12 10.189V14"/><path d="M12 2v3"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-8.188-3.639a2 2 0 0 0-1.624 0L3 14a11.6 11.6 0 0 0 2.81 7.76"/><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1s1.2 1 2.5 1c2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg></div>
            <p>Boats</p>
        </div>
        <div class="toggle-switch d-flex  flex-shrink-0">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input flex-shrink-0" type="checkbox" role="switch" id="switchCheckDefault">
                r<label class="form-check-label text-nowrap" for="switchCheckDefault">
                    <span class="d-none d-md-inline">Display total after taxes</span>
                    <span class="d-inline d-md-none">After taxes</span>
                </label>
            </div>
        </div>
    </div>
</nav>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for (let listing of allListings) { %>
    <a href="/listings/<%=listing._id %>" class="listing-link">
    <div class="card col listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style = "height: 20rem">
        <div class="card-img-overlay"></div>
        <div class="card-body">
            <p class="card-text"> 
            <b><%= listing.title %></b> <br>
            <button class="btn btn-primary">
                &#8377;<%= listing.price.toLocaleString("en-IN")%>/night &nbsp; &nbsp;
                <span class="badge rounded-pill bg-secondary">&nbsp; +12% G.S.T
                </span>
            </button>
            </p>
        </div>
    </div>
    </a>
    <% } %>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", ()=>{
        let taxInfo = document.getElementsByClassName("badge");
        for(info of taxInfo){
            if(info.style.display != "inline"){
                info.style.display = "inline";
            }else{
                info.style.display = "none";
            }
        }
    });
</script>
